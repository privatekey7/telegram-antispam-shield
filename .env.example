# --- Required ---------------------------------------------------------------
# Bot token from @BotFather (https://t.me/BotFather).
BOT_TOKEN=123456:ABC-DEF_your_token_here

# --- Optional behaviour -----------------------------------------------------
# What to do with a spammer: delete (default) | ban | mute
ANTISPAM_ACTION=delete

# Try the bot without deleting anything — only logs what it WOULD delete.
ANTISPAM_DRY_RUN=false

# Override the model's spam probability threshold (0.0 - 1.0).
# Higher = stricter about calling something spam (fewer deletions).
# Leave unset to use the tuned default baked into the model.
# ANTISPAM_THRESHOLD=0.85

# Treat Telegram invite links (t.me/+..., joinchat) as spam.
ANTISPAM_BLOCK_INVITE_LINKS=true

# Never moderate group administrators.
ANTISPAM_EXEMPT_ADMINS=true

# How long (seconds) to cache each group's admin list.
ANTISPAM_ADMIN_CACHE_TTL=3600

# Log verbosity: error | warn | info | debug | trace
RUST_LOG=info

# --- Advanced ---------------------------------------------------------------
# Path to a custom-trained model. Leave unset to use the built-in model.
# MODEL_PATH=/app/model/spam_model.bin
